# ── sUAS Dashboard Configuration ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# In Railway, set these as environment variables in the service settings.

# Google Sheets URL or Sheet ID (required for live data on Capabilities tab)
VITE_SHEET_URL=
VITE_SHEET_GID=0
VITE_REFRESH_MS=300000

# Admin PIN for Process Status and Idea Intake management (default: 1234)
ADMIN_PIN=1234

# Server port (Railway injects this automatically)
PORT=3000
