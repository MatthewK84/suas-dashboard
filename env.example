# ── sUAS Dashboard Configuration ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# In Railway, set these as environment variables in the service settings.

# Google Sheets URL or Sheet ID (required for live data)
# Accepts full URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
# Or just the sheet ID: 1aBcDeFgHiJkLmNoPqRsTuVwXyZ
VITE_SHEET_URL=

# Tab/GID within the sheet (default: 0 = first tab)
VITE_SHEET_GID=0

# Auto-refresh interval in milliseconds (default: 300000 = 5 minutes)
VITE_REFRESH_MS=300000
